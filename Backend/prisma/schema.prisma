generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int            @id @default(autoincrement())
  nome                   String
  email                  String         @unique
  senha                  String
  telefone               String         @default("")
  role                   Role           @default(USER)
  cep                    String         @default("")
  rua                    String         @default("")
  numeroEndereco         String         @default("")
  complemento            String         @default("")
  bairro                 String         @default("")
  cidade                 String         @default("Penedo")
  estado                 String         @default("AL")
  notificacoesHorarios   Boolean        @default(true)
  alertasTarifa          Boolean        @default(false)
  newsletter             Boolean        @default(false)
  cartaoNumero           String         @unique @default("4281")
  cartaoTipo             CartaoTipo     @default(COMUM)
  saldo                  Decimal        @default(0) @db.Decimal(10, 2)
  transacoes             Transacao[]
  notificacoes           Notificacao[]
  linhasMotorista        MotoristaLinha[]
  linhasCobrador         CobradorLinha[]
  localizacaoVeiculo     VeiculoLocalizacao?
  cobrancasFeitas        Cobranca[]     @relation("CobradorCobrancas")
  cobrancasRecebidas     Cobranca[]     @relation("PassageiroCobrancas")
  recargas               Recarga[]
  solicitacoesBeneficio   SolicitacaoBeneficio[]
  tokensRecuperacaoSenha  PasswordResetToken[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@map("users")
}

model Linha {
  id              Int          @id @default(autoincrement())
  numero          Int
  nome            String
  tipoTransporte  TipoTransporte
  tarifa          Decimal      @db.Decimal(10, 2)
  infoPagamento   String
  origem          String
  destino         String
  ativo           Boolean      @default(true)
  pontos          RotaPonto[]
  paradas         LinhaParada[]
  horarios        Horario[]
  motoristas      MotoristaLinha[]
  cobradores      CobradorLinha[]
  veiculosAtivos  VeiculoLocalizacao[]
  cobrancas       Cobranca[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("linhas")
}

model RotaPonto {
  id        Int      @id @default(autoincrement())
  linhaId   Int
  ordem     Int
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  linha     Linha    @relation(fields: [linhaId], references: [id], onDelete: Cascade)

  @@unique([linhaId, ordem])
  @@map("rota_pontos")
}

model Horario {
  id       Int       @id @default(autoincrement())
  linhaId  Int
  tipoDia  TipoDia
  horario  String
  ordem    Int       @default(0)
  linha    Linha     @relation(fields: [linhaId], references: [id], onDelete: Cascade)

  @@index([linhaId, tipoDia])
  @@map("horarios")
}

model LinhaParada {
  id        Int      @id @default(autoincrement())
  linhaId   Int
  ordem     Int
  nome      String
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  linha     Linha    @relation(fields: [linhaId], references: [id], onDelete: Cascade)

  @@unique([linhaId, ordem])
  @@map("linha_paradas")
}

model Faq {
  id        Int      @id @default(autoincrement())
  pergunta  String
  resposta  String   @db.Text
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model Notificacao {
  id        Int              @id @default(autoincrement())
  usuarioId Int?
  tipo      TipoNotificacao
  titulo    String
  descricao String           @db.Text
  lida      Boolean          @default(false)
  data      DateTime         @default(now())
  usuario   User?            @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("notificacoes")
}

model Transacao {
  id        Int           @id @default(autoincrement())
  usuarioId Int
  descricao String
  valor     Decimal       @db.Decimal(10, 2)
  tipo      TipoTransacao
  data      DateTime      @default(now())
  usuario   User          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("transacoes")
}

model MotoristaLinha {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  linhaId   Int
  usuario   User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  linha     Linha    @relation(fields: [linhaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([usuarioId, linhaId])
  @@map("motorista_linhas")
}

model VeiculoLocalizacao {
  id          Int      @id @default(autoincrement())
  usuarioId   Int      @unique
  linhaId     Int
  latitude    Decimal  @db.Decimal(10, 7)
  longitude   Decimal  @db.Decimal(10, 7)
  precisao    Decimal? @db.Decimal(10, 2)
  ativo       Boolean  @default(true)
  atualizadoEm DateTime @default(now())
  usuario     User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  linha       Linha    @relation(fields: [linhaId], references: [id], onDelete: Cascade)

  @@index([linhaId, ativo])
  @@map("veiculo_localizacoes")
}

model CobradorLinha {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  linhaId   Int
  usuario   User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  linha     Linha    @relation(fields: [linhaId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([usuarioId, linhaId])
  @@map("cobrador_linhas")
}

model Cobranca {
  id           Int            @id @default(autoincrement())
  cobradorId   Int
  passageiroId Int
  linhaId      Int
  valor        Decimal        @db.Decimal(10, 2)
  descontoPercentual Decimal  @default(0) @db.Decimal(5, 2)
  valorOriginal Decimal       @default(0) @db.Decimal(10, 2)
  status       StatusCobranca @default(APROVADA)
  codigoCartao String
  data         DateTime       @default(now())
  cobrador     User           @relation("CobradorCobrancas", fields: [cobradorId], references: [id], onDelete: Cascade)
  passageiro   User           @relation("PassageiroCobrancas", fields: [passageiroId], references: [id], onDelete: Cascade)
  linha        Linha          @relation(fields: [linhaId], references: [id], onDelete: Cascade)

  @@index([cobradorId, data])
  @@index([passageiroId, data])
  @@map("cobrancas")
}

model RegraCobranca {
  id                 Int        @id @default(autoincrement())
  tipoCartao         CartaoTipo @unique
  descontoPercentual Decimal    @default(0) @db.Decimal(5, 2)
  ativo              Boolean    @default(true)
  updatedAt          DateTime   @updatedAt
  createdAt          DateTime   @default(now())

  @@map("regras_cobranca")
}

model Recarga {
  id                    Int           @id @default(autoincrement())
  usuarioId             Int
  valor                 Decimal       @db.Decimal(10, 2)
  status                StatusRecarga @default(PENDENTE)
  preferenceId          String?
  paymentId             String?
  checkoutUrl           String?       @db.Text
  usuario               User          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([usuarioId, createdAt])
  @@map("recargas")
}

model SolicitacaoBeneficio {
  id              Int                       @id @default(autoincrement())
  usuarioId       Int
  tipoSolicitado  CartaoTipo
  status          StatusSolicitacaoBeneficio @default(PENDENTE)
  dados           String                    @db.Text
  observacao      String                    @default("") @db.Text
  documentoFrenteUrl String?                @db.Text
  documentoVersoUrl  String?                @db.Text
  respostaAdmin   String?                   @db.Text
  analisadoEm     DateTime?
  usuario         User                      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([usuarioId, createdAt])
  @@index([status, createdAt])
  @@map("solicitacoes_beneficio")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  usuarioId Int
  tokenHash String    @unique
  expiraEm  DateTime
  usadoEm   DateTime?
  usuario   User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([usuarioId, createdAt])
  @@map("password_reset_tokens")
}

enum Role {
  USER
  ADMIN
  MOTORISTA
  COBRADOR
}

enum TipoTransporte {
  onibus
  van
  barco
}

enum TipoDia {
  util
  sabado
  domingo_feriado
}

enum CartaoTipo {
  COMUM
  ESTUDANTE
  IDOSO
}

enum TipoNotificacao {
  alerta
  info
  sucesso
}

enum TipoTransacao {
  onibus
  van
  barco
  recarga
}

enum StatusCobranca {
  APROVADA
  RECUSADA
}

enum StatusRecarga {
  PENDENTE
  APROVADA
  RECUSADA
  CANCELADA
}

enum StatusSolicitacaoBeneficio {
  PENDENTE
  APROVADA
  RECUSADA
}
